{
  "rewrites": [
    {
      "source": "/api/account/settings",
      "destination": "/api/account/me?action=settings"
    },
    {
      "source": "/api/alerts/evaluate",
      "destination": "/api/alerts?action=evaluate"
    },
    {
      "source": "/:path((?!api/).*)",
      "destination": "/"
    }
  ]
}
