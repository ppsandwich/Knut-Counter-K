{
  "headers": [
    {
      "source": "/",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-store"
        }
      ]
    },
    {
      "source": "/index.html",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-store"
        }
      ]
    },
    {
      "source": "/sw.js",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-cache"
        }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/api/account/settings",
      "destination": "/api/account/me?action=settings"
    },
    {
      "source": "/api/alerts/evaluate",
      "destination": "/api/alerts?action=evaluate"
    },
    {
      "source": "/:path((?!api/).*)",
      "destination": "/"
    }
  ]
}
