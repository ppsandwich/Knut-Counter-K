{
  "compilerOptions": {
    "strict": true,
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "baseUrl": ".",
    "paths": {
      "@knut/ui": ["packages/ui/index.ts"],
      "@knut/ui/*": ["packages/ui/*"],
      "@knut/shared": ["packages/shared/index.ts"],
      "@knut/shared/*": ["packages/shared/*"],
      "@knut/providers": ["packages/providers/index.ts"],
      "@knut/providers/*": ["packages/providers/*"],
      "@knut/pricing": ["packages/pricing/index.ts"],
      "@knut/pricing/*": ["packages/pricing/*"],
      "@knut/db": ["packages/db/index.ts"],
      "@knut/db/*": ["packages/db/*"]
    }
  }
}
