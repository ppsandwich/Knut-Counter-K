{
  "name": "@knut/db",
  "version": "0.1.0",
  "private": true,
  "main": "index.ts",
  "types": "index.ts",
  "scripts": {
    "db:generate": "drizzle-kit generate --config drizzle.config.ts",
    "db:migrate": "drizzle-kit migrate --config drizzle.config.ts",
    "db:push": "drizzle-kit push --config drizzle.config.ts",
    "db:studio": "drizzle-kit studio --config drizzle.config.ts",
    "db:seed:providers": "tsx scripts/seedProviderRegistry.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@knut/pricing": "workspace:*",
    "@knut/providers": "workspace:*",
    "drizzle-orm": "^0.43.1",
    "postgres": "^3.4.5"
  },
  "devDependencies": {
    "dotenv": "^17.4.2",
    "drizzle-kit": "^0.31.10",
    "tsx": "^4.22.3",
    "typescript": "~5.8.3",
    "yaml": "^2.9.0"
  }
}
