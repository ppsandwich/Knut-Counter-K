{
  "name": "knut-counter",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@11.1.3",
  "scripts": {
    "build": "pnpm --filter @knut/mobile build:web",
    "dev": "pnpm --filter @knut/mobile start",
    "db:generate": "pnpm --filter @knut/db db:generate",
    "db:migrate": "pnpm --filter @knut/db db:migrate",
    "db:push": "pnpm --filter @knut/db db:push",
    "db:seed:providers": "pnpm --filter @knut/db db:seed:providers",
    "web": "pnpm --filter @knut/mobile web",
    "typecheck": "pnpm -r typecheck",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui"
  },
  "dependencies": {
    "@knut/db": "workspace:*",
    "@knut/pricing": "workspace:*",
    "@react-native-async-storage/async-storage": "~2.1.2",
    "react-native-gesture-handler": "^2.31.2",
    "react-native-reanimated": "~3.17.5"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@types/node": "^25.9.1",
    "@types/react": "^19.0.0",
    "playwright": "^1.60.0",
    "postgres": "^3.4.5",
    "turbo": "^2.5.0",
    "typescript": "~5.8.3"
  }
}
